          "name": "Zoho OAuth Callback (browser flow)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/zoho/oauth/callback?code=PLACEHOLDER&state={{tenantId}}",
            "description": "Exchanges Zoho `code` for `refresh_token`. Tenant: `tenantId` query or `state` from Zoho redirect (use `&state=kore` on authorize URL). Not a Twilio webhook."
          },
          "response": []
        }
