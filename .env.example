# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
# HTTP port (Forge sets this or defaults to 3000 behind Nginx)
PORT=3000
NODE_ENV=development

# Used to sign internal payloads if you extend JWT usage
JWT_SECRET=change-me

# Public base URL of this service (no trailing slash). Required in production
# for Twilio webhook signature validation (must match the URL Twilio POSTs to).
# Example: https://zoho-dialer-backend.example.com
PUBLIC_BASE_URL=http://localhost:3000

# Optional: comma-separated tenant slugs (speeds validation / inbound lookup)
# TENANT_SLUGS=kore,demo

# -----------------------------------------------------------------------------
# Multi-tenant Twilio (repeat per tenant slug, e.g. "kore")
# Namespaces use the slug in UPPERCASE: TWILIO_kore_ACCOUNT_SID
# -----------------------------------------------------------------------------

# TWILIO_{TENANT}_ACCOUNT_SID=
# TWILIO_{TENANT}_AUTH_TOKEN=

# Twilio Voice SDK access tokens require an API Key (Console: Account > API keys & tokens)
# TWILIO_{TENANT}_API_KEY_SID=
# TWILIO_{TENANT}_API_KEY_SECRET=

# TwiML App SID used by the browser/device client
# TWILIO_{TENANT}_TWIML_APP_SID=

# Outbound caller ID (verified Twilio number or verified caller ID)
# TWILIO_{TENANT}_CALLER_ID=

# Your tenant's Twilio number that receives inbound PSTN calls
# TWILIO_{TENANT}_INBOUND_NUMBER=+15551234567

# Pre-recorded voicemail audio URL (used by voicemail drop)
# TWILIO_{TENANT}_VOICEMAIL_URL=https://example.com/voicemail.mp3

# -----------------------------------------------------------------------------
# Multi-tenant Zoho CRM (repeat per tenant slug)
# ZOHO_kore_CLIENT_ID, etc.
# -----------------------------------------------------------------------------

# ZOHO_{TENANT}_CLIENT_ID=
# ZOHO_{TENANT}_CLIENT_SECRET=
# ZOHO_{TENANT}_REFRESH_TOKEN=
# ZOHO_{TENANT}_ORG_ID=

# OAuth redirect URL registered in Zoho API Console (must match authorize + token exchange exactly).
# If unset, defaults to {PUBLIC_BASE_URL}/api/v1/zoho/oauth/callback
# ZOHO_{TENANT}_REDIRECT_URI=https://your-backend.example.com/api/v1/zoho/oauth/callback

# Optional: Zoho Accounts host for this DC (default US). EU: https://accounts.zoho.eu
# ZOHO_{TENANT}_ACCOUNTS_DOMAIN=https://accounts.zoho.com

# Optional: CRM API host for this tenant's data center (default US)
# ZOHO_{TENANT}_API_DOMAIN=https://www.zohoapis.com
